# =============================================================================
# CNAP AI SIEM Copilot — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore
# NEVER add AWS credentials here — the EC2 instance uses its IAM role.
# =============================================================================

# --- Required: OpenSearch Configuration ---
OPENSEARCH_ENDPOINT=vpc-REPLACE_WITH_YOUR_ENDPOINT.us-gov-west-1.es.amazonaws.com
OPENSEARCH_INDICES=cwl-*,appgate-logs-*,security-logs-*

# --- Required: AWS Configuration ---
AWS_REGION=us-gov-west-1

# --- Required: S3 Buckets (from Terraform output) ---
S3_KNOWLEDGE_BUCKET=cnap-ai-siem-prod-knowledge-base-XXXXXXXX
S3_BACKUP_BUCKET=cnap-ai-siem-prod-backup-XXXXXXXX

# --- Optional: Model Configuration ---
MODEL_NAME=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# --- Optional: Analysis Configuration ---
TIME_RANGE_HOURS=720
INTERVAL_MINUTES=30
ENABLE_RAG=true
RAG_TOP_K=3

# --- Optional: Open WebUI ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBUI_SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING

# --- Optional: Logging ---
LOG_LEVEL=INFO
FLASK_ENV=production
